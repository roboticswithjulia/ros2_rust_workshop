
{
    "name": "ros2_rust_dev:latest",
    "build": {
    "context": "..",
    "dockerfile": "../.docker/Dockerfile",
    },
    "workspaceFolder": "/workspaces",
    "runArgs": [
    "--network=host",
    "--hostname=devcontainer",
    "--privileged"
    ],
    "mounts": [
      "source=${localWorkspaceFolder},target=/workspaces/docs,type=bind"
    ]
}